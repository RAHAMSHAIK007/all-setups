# 1. Elevate to root users
sudo -i

# 2. Set the appropriate hostname (Uncomment/run ONE option per server)
hostnamectl set-hostname ansible
hostnamectl set-hostname dev-1
hostnamectl set-hostname dev-2
hostnamectl set-hostname test-1
hostnamectl set-hostname test-2

# 3. Reload terminal environment to show updated hostname
sudo -i

# 4. Set the root password (Run manually to establish initial SSH copy password)
passwd root

# 5. Enable root login and password authentication over SSH in AL2023
# (Automates the manual 'uncomment 38' and 'change no=yes 63' steps)
sed -i 's/#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sed -i 's/PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config

# 6. Restart SSH service to apply changes
systemctl restart sshd
systemctl status sshd --no-pager

# ==============================================================================
ANSIBLE CONTROL SERVER ONLY (Execute ONLY on the Ansible server)
# ==============================================================================

# 1. Update package index and install Ansible along with Python3 prerequisites
# Note: AL2023 drops amazon-linux-extras; we use dnf directly.
dnf clean all
dnf install ansible-core python3 python3-pip python3-devel -y

# 2. Create the configuration directory if missing
mkdir -p /etc/ansible

# 3. Generate the inventory file with your specified node IPs
vim /etc/ansible/hosts
[dev]
your private ip
your private ip

[test]
your private ip
your private ip

# 4. Generate the SSH Keypair non-interactively 
ssh-keygen

# 5. Establish SSH Trust with Dev Nodes
# (Run these; you will be prompted to type 'yes' and enter the root password)
ssh-copy-id root@your private ip
ssh root@your private ip "exit"

# (Type 'yes' and enter the root password)
ssh-copy-id root@your private ip
ssh root@your private ip "exit"

# 6. Establish SSH Trust with Test Nodes
# (Type 'yes' and enter the root password)
ssh-copy-id root@your private ip
ssh root@your private ip "exit"

# (Type 'yes' and enter the root password)
ssh-copy-id root@your private ip
ssh root@your private ip "exit"

# 7. Final Verification
ansible -m ping all
